# OffMe local development environment

# API
API_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Password reset e-mail (opcional — Resend free tier)
# RESEND_API_KEY=re_...
# RESEND_FROM=OffMe <noreply@seu-dominio.com>

# PostgreSQL (auth + relational data)
DATABASE_URL=postgresql://offme:offme_dev@localhost:5432/offme
POSTGRES_URL=jdbc:postgresql://localhost:5432/offme?user=offme&password=offme_dev
POSTGRES_USER=offme
POSTGRES_PASSWORD=offme_dev
POSTGRES_DB=offme

# Auth
JWT_SECRET=change_me_in_production_use_long_random_string

# MinIO — armazenamento de imagens (S3-compatible, perfil minimal)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=offme
S3_SECRET_KEY=offme_dev
S3_BUCKET=offme-media
S3_PUBLIC_URL=http://localhost:9000/offme-media
S3_REGION=us-east-1

# Cassandra (posts + timelines)
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=offme

# Redis (cache + feature store)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Neo4j (social graph)
NEO4J_URL=bolt://localhost:7687
NEO4J_AUTH=neo4j/offme_dev

# Elasticsearch (search)
ELASTICSEARCH_URL=http://localhost:9200

# Kafka (events)
KAFKA_BOOTSTRAP=localhost:9092

# Observability
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
PROMETHEUS_URL=http://localhost:9090

# Supabase Realtime (opcional em dev local; use com Postgres do Supabase)
# NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Produção — ver docs/deploy.md e frontend-web/.env.production.example

# Service tuning
CELEBRITY_THRESHOLD=10000
TIMELINE_PAGE_SIZE=20
FANOUT_BATCH_SIZE=500