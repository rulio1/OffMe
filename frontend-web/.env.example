# PostgreSQL (auth via API Routes do Next.js)
DATABASE_URL=postgresql://offme:offme_dev@localhost:5432/offme

# JWT para access tokens (mín. 32 caracteres em produção)
JWT_SECRET=change_me_in_production_use_long_random_string

# Administradores (usernames separados por vírgula)
ADMIN_USERNAMES=admin,moderator

# true = login mock sem banco (apenas UI)
NEXT_PUBLIC_DEV_AUTH=false

# MinIO — upload de imagens (rode: make minimal)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=offme
S3_SECRET_KEY=offme_dev
S3_BUCKET=offme-media
S3_PUBLIC_URL=http://localhost:9000/offme-media
S3_REGION=us-east-1

# Supabase Realtime (postgres_changes em notificações e mensagens)
# Use o mesmo Postgres do Supabase em DATABASE_URL e configure o JWT Secret
# no painel Supabase (Settings → API → JWT Secret) igual ao JWT_SECRET abaixo.
# NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# (ou NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... — formato legado)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  # opcional, só para uso server-side

# ImgBB (alternativa simples ao S3 para imagens em produção)
# IMGBB_API_KEY=

# Push notifications (Web Push / VAPID)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@offme.app
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # same as VAPID_PUBLIC_KEY for browser subscribe

# Cron — publicação de posts agendados (Vercel Cron)
# CRON_SECRET=

# Push nativo iOS (APNs HTTP/2 — chave .p8 da Apple Developer)
# APNS_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_TOPIC=com.offme.app
# APNS_PRODUCTION=true

# Push nativo Android (Firebase Cloud Messaging — legacy server key)
# FCM_SERVER_KEY=

# FCM opcional para push iOS/Android
# FCM_SERVER_KEY=

# API Gateway Scala (quando microserviços estiverem rodando)
# API_GATEWAY_URL=http://localhost:8080
# NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1