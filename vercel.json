{
  "version": 2,
  "builds": [
    {
      "src": "frontend-web/package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "https://$RAILWAY_BACKEND_URL/api/v1/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/ws/(.*)",
      "dest": "wss://$RAILWAY_BACKEND_URL/ws/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://$RAILWAY_BACKEND_URL/api/v1",
    "NEXT_PUBLIC_WS_URL": "wss://$RAILWAY_BACKEND_URL/ws",
    "NEXT_PUBLIC_PLAUSIBLE_DOMAIN": "offme.vercel.app",
    "NEXT_PUBLIC_SITE_URL": "https://offme.vercel.app"
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/v1/health"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}