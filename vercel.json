{
  "version": 2,
  "builds": [
    {
      "src": "frontend-web/package.json",
      "use": "@vercel/next",
      "config": {
        "zeroConfig": true
      }
    },
    {
      "src": "backend-scala/api-gateway/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/api-gateway/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/identity-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/identity-service/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/post-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/post-service/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/timeline-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/timeline-service/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/graph-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/graph-service/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/notification-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/notification-service/Dockerfile",
        "zeroConfig": false
      }
    },
    {
      "src": "backend-scala/websocket-service/Dockerfile",
      "use": "@vercel/docker",
      "config": {
        "dockerfilePath": "backend-scala/websocket-service/Dockerfile",
        "zeroConfig": false
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/v1/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/ws/(.*)",
      "dest": "/ws/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "/api/v1",
    "NEXT_PUBLIC_WS_URL": "wss://offme.vercel.app/ws",
    "NEXT_PUBLIC_PLAUSIBLE_DOMAIN": "offme.vercel.app",
    "NEXT_PUBLIC_SITE_URL": "https://offme.vercel.app",
    "IDENTITY_SERVICE_URL": "http://localhost:8081",
    "POST_SERVICE_URL": "http://localhost:8082",
    "TIMELINE_SERVICE_URL": "http://localhost:8083",
    "GRAPH_SERVICE_URL": "http://localhost:8084",
    "NOTIFICATION_SERVICE_URL": "http://localhost:8085",
    "WEBSOCKET_SERVICE_URL": "http://localhost:8086"
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/v1/health"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}