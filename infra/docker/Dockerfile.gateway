FROM eclipse-temurin:21-jdk-alpine AS build
WORKDIR /app
COPY . .
RUN ./sbt apiGateway/assembly 2>/dev/null || echo "sbt build skipped in skeleton"

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /app/api-gateway/target/offme-api-gateway.jar app.jar 2>/dev/null || true
EXPOSE 8080
CMD ["sh", "-c", "java -jar app.jar 2>/dev/null || echo 'API Gateway skeleton — run sbt apiGateway/run locally' && sleep infinity"]