# Copie para secrets/push-keys.env e preencha (NÃO commite push-keys.env)
#
# Apple Developer → Certificates, Identifiers & Profiles → Keys
#   Crie uma chave APNs (.p8), anote Key ID
#
# Firebase Console → Project Settings → Cloud Messaging → Server key (legacy)

APNS_KEY_ID=XXXXXXXXXX
APNS_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
FCM_SERVER_KEY=AAAA...your_server_key...

# Já conhecidos do projeto (opcional sobrescrever)
APNS_TEAM_ID=HP25CSYA96
APNS_TOPIC=com.offme.app
APNS_PRODUCTION=false